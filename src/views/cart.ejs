<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart - Ecommerce</title>

    <link rel="stylesheet" href="/css/components/userDropdown.css">
    <link rel="stylesheet" href="/css/layouts/header.css">
    <link rel="stylesheet" href="/css/components/searchBar.css">
    <link rel="stylesheet" href="/css/components/cartAndProfile.css">
    <link rel="stylesheet" href="/css/views/cart.css">
    <link rel="stylesheet" href="/css/components/breadCrumb.css">
    <link rel="stylesheet" href="/css/components/productCart.css">
    <link rel="stylesheet" href="/css/layouts/footer.css">
</head>
<body>
    <% let totalPoints = 0; %>

    <%- include('components/userDropdown') %>
    <%- include('layouts/header', { loggedIn: loggedIn }) %>
    <main>
        <div class="container">
            <%- include('components/breadCrumb', { page: 'cart' }) %>
            <% if (cartProducts.length !== 0) { %>
                <h1>Productos en tu Carrito</h1>
                <div class="product">
                    <% cartProducts.forEach(product => { %>
                        <%- include('components/productCart', { 
                            id: product.id,
                            name: product.name,
                            image: product.image,
                            points: product.points,
                            quantity: product.quantity,
                            category: product.category
                        }) %>
                        <% 
                        // Convertimos a texto, quitamos TODOS los puntos (separadores de miles) y luego convertimos a número
                        let puntosLimpios = String(product.subtotal).replace(/\./g, '');
                        totalPoints += Number(puntosLimpios) || 0; 
                        %>
                    <% }) %>

                </div>
                <div class="checkout">
                    <!-- Mostramos el total formateado correctamente (ej: 19.900) -->
                    <h1>Total de puntos: <%= new Intl.NumberFormat('es-CL').format(totalPoints) %></h1>
                    
                    <a href="/checkout" class="button-pay">Ir a Pagar</a>
                </div>
            <% } else { %>
                <h1 class="empty-cart-title">Tu carrito está vacío.</h1>
            <% } %>
        </div>
    </main>
    <%- include('layouts/footer') %>

    <script src="/js/dropdown.js"></script>
</body>
</html>