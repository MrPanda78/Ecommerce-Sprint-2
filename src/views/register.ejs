<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Ecommerce</title>

    <link rel="stylesheet" href="/css/layouts/header.css">
    <link rel="stylesheet" href="/css/views/login-register.css">
    <link rel="stylesheet" href="/css/layouts/footer.css">
</head>
<body>
    <%- include('layouts/header', { loggedIn: loggedIn }) %>
    <main>
        <div>
            <h2>¡Registrate!</h2>
            <input type="text" name="email" placeholder="Tu email" autocomplete="email">
            <input type="text" name="password" placeholder="Tu nueva contraseña">
            <input type="text" name="password-repeat" placeholder="Repite tu contraseña">

            <a href="/">Crear Cuenta</a>
        </div>
        <h5>¿Ya tienes cuenta? <a href="/login">Iniciar Sesión</a></h5>
    </main>
    <%- include('layouts/footer') %>
</body>
</html>